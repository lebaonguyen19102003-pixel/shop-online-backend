extends ../../layouts/default.pug
include ../../mixins/box-head.pug

block main
  .container.my-3 

    include ../../partials/list-btn-users.pug

    .row 
      .col-12 
        +box-head("Danh sách bạn bè")

    .row(data-users-friends=user.id)
      div(my-id=user.id)
      each user in users
        .col-6(user-id=user.id)
          div(class="box-user")
            div(class="inner-avatar")
              img(
                src=(user.avatar ? user.avatar : "/images/default-avatar.jpg")
                alt=user.fullName
              )
            div(class="inner-info")
              div(class="inner-name") #{user.fullName}
              div(class="inner-buttons")
                a(
                  href=`/chat/${user.infoFriend.room_chat_id}`
                  class="btn btn-sm btn-primary mr-1"
                ) Nhắn tin
            div(
              class="inner-status"
              status=user.statusOnline
            )
              i.fa-solid.fa-circle
                

block script 
  script(type="module", src="/js/users.js")