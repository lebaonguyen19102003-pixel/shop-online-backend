extends ../../layouts/default.pug
include ../../mixins/box-head.pug

block main
  .container.my-3 
    .row 
      .col-12 
        +box-head("Sửa phòng")

    .row 
      .col-12 
        form(
          action=`/rooms-chat/edit/${roomChat.id}?_method=PATCH`
          method="POST"
          enctype="multipart/form-data"
        )
          div(class="form-group")
            label(for="title") Tiêu đề
            input(
              type="text"
              class="form-control"
              id="title"
              name="title"
              required
              value=roomChat.title
            )
          div(class="form-group")
            label Thêm thành viên
            each friend in friendList
              div(class="form-check d-flex align-items-center")
                input(
                  class="form-check-input"
                  type="checkbox"
                  value=friend.user_id
                  id=`user-${friend.user_id}`
                  name="usersId"
                  checked=(roomChat.users.some(user => user.user_id == friend.user_id))
                )
                img(
                  src=friend.infoFriend.avatar
                  style="width: 40px; height: 40px; object-fit: cover;"
                  class="rounded-circle mx-2"
                )
                label(
                  class="form-check-label"
                  for=`user-${friend.user_id}`
                ) #{friend.infoFriend.fullName}
          div(
            class="form-group"
            upload-image
          )
            label(for="avatar") Ảnh đại diện
            input(
              type="file"
              class="form-control-file"
              id="avatar"
              name="avatar"
              accept="image/*"
              upload-image-input
            )
            img(
              src=roomChat.avatar
              upload-image-preview
              class="image-preview"
            )
          div(class="form-group")
            button(
              type="submit"
              class="btn btn-primary"
            ) Cập nhật

block script 
  script(type="module", src="/js/users.js")