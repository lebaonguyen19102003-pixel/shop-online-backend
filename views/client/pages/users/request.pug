extends ../../layouts/default.pug
include ../../mixins/box-head.pug

block main
  .container.my-3 

    include ../../partials/list-btn-users.pug

    .row 
      .col-12 
        +box-head("Lời mời đã gửi")

    .row 
      div(my-id=user.id)
      each user in users
        .col-6 
          div(class="box-user add")
            div(class="inner-avatar")
              img(
                src=(user.avatar ? user.avatar : "/images/default-avatar.jpg")
                alt=user.fullName
              )
            div(class="inner-info")
              div(class="inner-name") #{user.fullName}
              div(class="inner-buttons")
                button(
                  class="btn btn-sm btn-primary mr-1"
                  btn-add-friend=user.id
                ) Kết bạn
                button(
                  class="btn btn-sm btn-secondary mr-1"
                  btn-cancel-friend=user.id
                ) Hủy

block script 
  script(type="module", src="/js/users.js")

  // SocketIO
  script(src="/socket.io/socket.io.js")
  script(src="/js/socket.js")
  // End SocketIO