extends ../../layouts/default.pug
include ../../mixins/box-head.pug

block css 
  //- file-upload-with-preview
  link(
    rel="stylesheet"
    type="text/css"
    href="https://unpkg.com/file-upload-with-preview/dist/style.css"
  )
  //- End file-upload-with-preview

  //- viewerjs
  link(
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/viewerjs/1.11.7/viewer.css"
  )
  //- End viewerjs

block main
  .container.my-3

    div(user-info=`${JSON.stringify(user)}`)
    div(room-chat-id=roomChatId)

    include ../../partials/list-btn-users.pug
    
    .row
      .col-12
        +box-head("Chat")
        
    .row
      .col-12
        .chat(my-id=user.id)
          .inner-head
            .inner-avatar
              img(
                src=(chatData.avatar ? chatData.avatar : "/images/default-avatar.jpg")
                alt=chatData.name
              )
            .inner-name #{chatData.name}
          .inner-body
            each chat in chats
              div(class=(chat.user_id == user.id ? "inner-outgoing" : "inner-incoming"))
                if (chat.user_id != user.id)
                  .inner-name #{chat.infoUser.fullName}
                if (chat.content)
                  .inner-content
                    | #{chat.content}
                if (chat.images)
                  .inner-images
                    each image of chat.images
                      img(src=image)
            //- Typing
            div(class="inner-list-typing")
          
          //- file-upload-with-preview
          .inner-preview-images
            div(
              class="custom-file-container"
              data-upload-id="upload-images"
            )
          //- End file-upload-with-preview

          .inner-foot
            form(
              class="inner-form"
              action=""
            )
              input(
                type="text"
                placeholder="Nhập nội dung..."
                name="content"
              )
              label(
                class="btn btn-light mx-2 mb-0"
                for="file-upload-with-preview-upload-images"
              )
                i.fa-regular.fa-image
              span(class="button-icon btn btn-light mx-2")
                i.fa-regular.fa-face-smile
              button
                i.fa-solid.fa-paper-plane
  
  div(class="tooltip" role="tooltip")
    emoji-picker(class="light")

block script 
  script(type="module" src="/js/chat.js")

  // emoji-picker-element
  script(type="module", src="https://cdn.jsdelivr.net/npm/emoji-picker-element@^1/index.js")
  // End emoji-picker-element

  //- viewerjs
  script(src="https://cdnjs.cloudflare.com/ajax/libs/viewerjs/1.11.7/viewer.js")
  //- End viewerjs